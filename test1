local function styleButton(btn, text, posY, bgColor)
	btn.Parent = MainFrame
	btn.BackgroundColor3 = bgColor
	btn.BorderColor3 = Color3.fromRGB(255, 255, 255)
	btn.Position = UDim2.new(0.1, 0, 0, posY)
	btn.Size = UDim2.new(0.8, 0, 0, 25)
	btn.Font = Enum.Font.SciFi
	btn.Text = text .. " [OFF]"
	btn.TextColor3 = Color3.fromRGB(255, 255, 255)
	btn.TextStrokeTransparency = 0.5
	btn.TextSize = 16
end

styleButton(GuardButton, "Guards", 60, TeamColors.Guards)
styleButton(InmateButton, "Inmates", 90, TeamColors.Inmates)
styleButton(CriminalButton, "Criminals", 120, TeamColors.Criminals)
styleButton(ESPButton, "ESP Players", 155, Color3.fromRGB(150, 0, 200))
styleButton(ResetButton, "disable", 195, Color3.fromRGB(30, 30, 30))
ResetButton.Text = "disable"

RunService.RenderStepped:Connect(function()
	for _, player in pairs(Players:GetPlayers()) do
		if player ~= LocalPlayer and player.Character and player.Character:FindFirstChild("HumanoidRootPart") and player.Character:FindFirstChild("Humanoid") then
			pcall(function()
				local hrp = player.Character.HumanoidRootPart
				local hum = player.Character.Humanoid
				
				if hum.Health > 0 and player.Team and ActiveTeams[player.Team.Name] then
					hrp.Size = Vector3.new(HitboxSize, HitboxSize, HitboxSize)
					hrp.Transparency = 0.5
					hrp.BrickColor = BrickColor.new("Really blue")
					hrp.Material = Enum.Material.Neon
					hrp.CanCollide = false
				else
					if hrp.Size.X > 2 then
						hrp.Size = Vector3.new(2, 2, 1)
						hrp.Transparency = 1
						hrp.CanCollide = true
					end
				end
			end)
		end
	end
end)

task.spawn(function()
	while task.wait(0.1) do
		for _, player in pairs(Players:GetPlayers()) do
			if player ~= LocalPlayer and player.Character then
				local char = player.Character
				local pTeamColor = player.Team and player.Team.TeamColor.Color or Color3.fromRGB(255, 255, 255)
				
				local highlight = char:FindFirstChild("TeamHighlight")
				local espName = char:FindFirstChild("ESPNameTag")

				if ESPEnabled and char:FindFirstChild("Humanoid") and char.Humanoid.Health > 0 then
					if not highlight then
						highlight = Instance.new("Highlight")
						highlight.Name = "TeamHighlight"
						highlight.Parent = char
					end
					highlight.FillColor = pTeamColor
					highlight.OutlineColor = pTeamColor
					highlight.FillTransparency = 0.6
					highlight.OutlineTransparency = 0.1
					
					if not espName and char:FindFirstChild("Head") then
						espName = Instance.new("BillboardGui")
						espName.Name = "ESPNameTag"
						espName.Size = UDim2.new(0, 100, 0, 40)
						espName.StudsOffset = Vector3.new(0, 2, 0)
						espName.AlwaysOnTop = true
						espName.Parent = char

						local textLabel = Instance.new("TextLabel")
						textLabel.Parent = espName
						textLabel.Size = UDim2.new(1, 0, 1, 0)
						textLabel.BackgroundTransparency = 1
						textLabel.Font = Enum.Font.SourceSansBold
						textLabel.TextScaled = true
						textLabel.TextStrokeTransparency = 0
						textLabel.TextColor3 = pTeamColor
						textLabel.Text = player.Name
					else
						if espName and espName:FindFirstChild("TextLabel") then
							espName.TextLabel.TextColor3 = pTeamColor
						end
					end
				else
					if highlight then highlight:Destroy() end
					if espName then espName:Destroy() end
				end
			end
		end
	end
end)

local function toggleTeam(teamName, button, baseText)
	ActiveTeams[teamName] = not ActiveTeams[teamName]
	if ActiveTeams[teamName] then
		button.Text = baseText .. " [ON]"
		button.BackgroundTransparency = 0.2
	else
		button.Text = baseText .. " [OFF]"
		button.BackgroundTransparency = 0
	end
end

GuardButton.MouseButton1Click:Connect(function()
	toggleTeam("Guards", GuardButton, "Guards")
end)

InmateButton.MouseButton1Click:Connect(function()
	toggleTeam("Inmates", InmateButton, "Inmates")
end)

CriminalButton.MouseButton1Click:Connect(function()
	toggleTeam("Criminals", CriminalButton, "Criminals")
end)

ESPButton.MouseButton1Click:Connect(function()
	ESPEnabled = not ESPEnabled
	if ESPEnabled then
		ESPButton.Text = "ESP Players [ON]"
		ESPButton.BackgroundTransparency = 0.2
	else
		ESPButton.Text = "ESP Players [OFF]"
		ESPButton.BackgroundTransparency = 0
	end
end)

ResetButton.MouseButton1Click:Connect(function()
	ActiveTeams["Guards"] = false
	ActiveTeams["Inmates"] = false
	ActiveTeams["Criminals"] = false
	ESPEnabled = false
	
	GuardButton.Text = "Guards [OFF]"; GuardButton.BackgroundTransparency = 0
	InmateButton.Text = "Inmates [OFF]"; InmateButton.BackgroundTransparency = 0
	CriminalButton.Text = "Criminals [OFF]"; CriminalButton.BackgroundTransparency = 0
	ESPButton.Text = "ESP Players [OFF]"; ESPButton.BackgroundTransparency = 0
end)

local UserInputService = game:GetService("UserInputService")
UserInputService.InputBegan:Connect(function(input, gameProcessed)
	if not gameProcessed and input.KeyCode == Enum.KeyCode.Equals then
		MainFrame.Visible = not MainFrame.Visible
	end
end)
